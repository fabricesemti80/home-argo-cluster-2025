---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana
  annotations:
    external-dns.alpha.kubernetes.io/hostname: grafana.#{ cloudflare_domain }#
    external-dns.alpha.kubernetes.io/target: internal.#{ cloudflare_domain }#
spec:
  parentRefs:
    - name: envoy-internal
      namespace: network
  hostnames:
    - grafana.#{ cloudflare_domain }#
  rules:
    - backendRefs:
        - name: kube-prometheus-stack-grafana
          namespace: monitoring
          port: 80
